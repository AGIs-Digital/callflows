# Aktiviere die RewriteEngine
RewriteEngine On

# Basis-URL setzen
RewriteBase /

# Erlaube direkte Zugriffe auf statische Dateien und wichtige Pfade
RewriteCond %{REQUEST_URI} \.(js|css|svg|jpg|jpeg|webp|gif|ico|woff2)$ [OR]
RewriteCond %{REQUEST_URI} ^/api/ [OR]
RewriteCond %{REQUEST_URI} ^/blog/?$ [OR]
RewriteCond %{REQUEST_URI} ^/blog/.+$
RewriteRule ^ - [L]

# Alle anderen Anfragen an _next/static durchlassen
RewriteCond %{REQUEST_URI} ^/_next/static/
RewriteRule ^ - [L]

# Alle anderen Anfragen an index.html weiterleiten
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^(.*)$ /index.html [QSA,L]

# Aktiviere GZIP-Komprimierung (erweitert für maximale Performance)
<IfModule mod_deflate.c>
    # Text-basierte Dateien
    AddOutputFilterByType DEFLATE text/plain
    AddOutputFilterByType DEFLATE text/html
    AddOutputFilterByType DEFLATE text/xml
    AddOutputFilterByType DEFLATE text/css
    AddOutputFilterByType DEFLATE text/javascript
    
    # Application-Dateien
    AddOutputFilterByType DEFLATE application/xml
    AddOutputFilterByType DEFLATE application/xhtml+xml
    AddOutputFilterByType DEFLATE application/rss+xml
    AddOutputFilterByType DEFLATE application/javascript
    AddOutputFilterByType DEFLATE application/x-javascript
    AddOutputFilterByType DEFLATE application/json
    AddOutputFilterByType DEFLATE application/ld+json
    
    # Web-Fonts (weitere Komprimierung)
    AddOutputFilterByType DEFLATE font/ttf
    AddOutputFilterByType DEFLATE font/otf
    AddOutputFilterByType DEFLATE font/eot
    AddOutputFilterByType DEFLATE application/font-woff
    AddOutputFilterByType DEFLATE application/font-woff2
    
    # SVG und weitere Formate
    AddOutputFilterByType DEFLATE image/svg+xml
    AddOutputFilterByType DEFLATE application/vnd.ms-fontobject
    
    # Komprimierungslevel erhöhen (1-9, 9 = maximal)
    DeflateCompressionLevel 9
    
    # Exclude bereits komprimierte Dateien
    SetEnvIfNoCase Request_URI \.(?:gif|jpe?g|png|webp|woff2?)$ no-gzip dont-vary
    SetEnvIfNoCase Request_URI \.(?:exe|t?gz|zip|bz2|sit|rar)$ no-gzip dont-vary
</IfModule>

# Browser Caching (aggressiv optimiert für statischen Export)
<IfModule mod_expires.c>
    ExpiresActive On
    
    # Bilder - 1 Jahr (ändern sich selten)
    ExpiresByType image/jpg "access plus 1 year"
    ExpiresByType image/jpeg "access plus 1 year"
    ExpiresByType image/gif "access plus 1 year"
    ExpiresByType image/png "access plus 1 year"
    ExpiresByType image/webp "access plus 1 year"
    ExpiresByType image/svg+xml "access plus 1 year"
    ExpiresByType image/x-icon "access plus 1 year"
    
    # Fonts - 1 Jahr (ändern sich sehr selten)
    ExpiresByType font/woff "access plus 1 year"
    ExpiresByType font/woff2 "access plus 1 year"
    ExpiresByType font/ttf "access plus 1 year"
    ExpiresByType font/otf "access plus 1 year"
    ExpiresByType application/x-font-woff "access plus 1 year"
    ExpiresByType application/font-woff2 "access plus 1 year"
    ExpiresByType application/vnd.ms-fontobject "access plus 1 year"
    
    # CSS & JavaScript - 6 Monate (statischer Export = seltene Änderungen)
    ExpiresByType text/css "access plus 6 months"
    ExpiresByType application/javascript "access plus 6 months"
    ExpiresByType application/x-javascript "access plus 6 months"
    ExpiresByType text/javascript "access plus 6 months"
    
    # HTML - 1 Woche (für Content-Updates)
    ExpiresByType text/html "access plus 1 week"
    
    # JSON/XML - 1 Tag
    ExpiresByType application/json "access plus 1 day"
    ExpiresByType application/xml "access plus 1 day"
    ExpiresByType text/xml "access plus 1 day"
    
    # Manifeste und Konfigurationsdateien - 1 Monat
    ExpiresByType application/manifest+json "access plus 1 month"
    ExpiresByType application/x-web-app-manifest+json "access plus 1 month"
    
    # PDFs und andere Dokumente
    ExpiresByType application/pdf "access plus 1 month"
</IfModule>

# Korrekte MIME-Types für statischen Export
<IfModule mod_mime.c>
    # CSS MIME Type explizit setzen
    AddType text/css .css
    AddType application/javascript .js
    AddType font/woff2 .woff2
    AddType font/woff .woff
    AddType image/webp .webp
</IfModule>

# Setze Sicherheitsheader
<IfModule mod_headers.c>
    Header set Referrer-Policy "strict-origin-when-cross-origin"
    
    # CSS spezielle Behandlung gegen MIME Fehler
    <FilesMatch "\.css$">
        Header set Content-Type "text/css; charset=utf-8"
        Header unset Content-Security-Policy
    </FilesMatch>
    
    # Cache-Control für statische Assets (aggressiv für statischen Export)
    <FilesMatch "\.(ico|pdf|jpg|jpeg|webp|gif|svg|woff|woff2|ttf|otf|eot)$">
        Header set Cache-Control "max-age=31536000, public, immutable"
        Header set Vary "Accept-Encoding"
    </FilesMatch>
    
    # Cache-Control für CSS/JS (6 Monate mit Versionierung)
    <FilesMatch "\.(css|js)$">
        Header set Cache-Control "max-age=15552000, public, immutable"
        Header set Vary "Accept-Encoding"
    </FilesMatch>
    
    # Cache-Control für HTML (kurz für Content-Updates)
    <FilesMatch "\.(html|htm)$">
        Header set Cache-Control "max-age=604800, public, must-revalidate"
        Header set Vary "Accept-Encoding"
    </FilesMatch>
    
    # Cache-Control für JSON/XML
    <FilesMatch "\.(json|xml)$">
        Header set Cache-Control "max-age=86400, public"
        Header set Vary "Accept-Encoding"
    </FilesMatch>
    
    # Permissions Policy für Mikrofon und Kamera
    Header set Permissions-Policy "microphone=self, camera=self, geolocation=self"
    
    # Schutz vor XSS-Angriffen
    Header set X-XSS-Protection "1; mode=block"

    # Verhindern von MIME-Type-Sniffing
    Header set X-Content-Type-Options "nosniff"

    # HTTP Strict Transport Security (HSTS)
    Header set Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"

    # Content Security Policy für bessere Sicherheit
    Header set Content-Security-Policy "frame-ancestors 'self'; object-src 'none'; base-uri 'self';"
    
    # Fallback für ältere Browser (X-Frame-Options)
    Header set X-Frame-Options "SAMEORIGIN"
</IfModule>

# Verhindern Sie den Zugriff auf versteckte Dateien
<FilesMatch "^\.">
    Order allow,deny
    Deny from all
</FilesMatch>

# Optimiere die Leistung durch Komprimierung von Bildern
<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteCond %{HTTP_ACCEPT} image/webp
    RewriteCond %{REQUEST_FILENAME} -f
    RewriteCond %{REQUEST_FILENAME} \.(jpg|jpeg|webp)$
    RewriteCond %{REQUEST_FILENAME}\.webp -f
    RewriteRule ^(.*)\.(jpg|jpeg|webp)$ $1\.$2\.webp [T=image/webp,L]
</IfModule> 